<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
    <title>نور</title>
    <meta name="theme-color" content="#0f172a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="نور">
    <style>
        * { -webkit-tap-highlight-color: transparent; outline: 0; box-sizing: border-box; }
        body {
            font-family: system-ui, sans-serif;
            direction: rtl;
            margin: 0;
            background: linear-gradient(135deg, #0f172a, #1e1b4b, #0f172a);
            color: #e2e8f0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 12px
        }
        @supports(padding:max(0px)) {
            body {
                padding-top: max(16px, env(safe-area-inset-top));
                padding-left: max(12px, env(safe-area-inset-left));
                padding-right: max(12px, env(safe-area-inset-right));
                padding-bottom: max(16px, env(safe-area-inset-bottom))
            }
        }
        .main-grid {
            max-width: 72rem;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr;
            gap: 16px
        }
        @media(min-width:768px) { .main-grid { grid-template-columns: 1fr 1fr; gap: 24px } }
        @media(min-width:1024px) { .main-grid { grid-template-columns: repeat(12, 1fr); gap: 24px } }
        .panel {
            background: rgba(255, 255, 255, .05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, .1);
            border-radius: 24px;
            padding: 16px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, .5);
            position: relative
        }
        @media(min-width:640px) { .panel { padding: 24px } }
        .prayer-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255, 255, 255, .05);
            padding: 12px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, .05);
            transition: all .2s
        }
        @media(min-width:640px) { .prayer-card { padding: 14px } }
        .prayer-card.active {
            background: rgba(20, 184, 166, .2);
            border-color: rgba(45, 212, 191, .6);
            box-shadow: 0 0 20px rgba(20, 184, 166, .2);
            transform: scale(1.01)
        }
        .prayer-card.active span:first-child { color: #2dd4bf; font-weight: 700 }
        .circle-container { width: 340px; height: 340px; position: relative }
        @media(min-width:640px) { .circle-container { width: 378px; height: 378px } }
        .prayer-time { font-family: monospace; font-size: 1.1rem }
        .digital-clock { font-family: monospace; font-weight: 900; color: #5eead4; text-shadow: 0 0 12px rgba(45, 212, 191, .15) }
        .countdown-timer { font-family: monospace; font-weight: 700; color: #6ee7b7 }
        .gradient-text { background: linear-gradient(to right, #2dd4bf, #34d399); -webkit-background-clip: text; -webkit-text-fill-color: transparent }
        button:active { opacity: .7; transform: scale(.97) }
        
        .cal-day {
            padding: 6px 2px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            font-weight: 600;
            min-height: 44px;
            border: 1px solid transparent;
            transition: all 0.2s;
        }
        .cal-day.today {
            background: linear-gradient(135deg, #14b8a6, #10b981);
            color: #0f172a;
            font-weight: 800;
            transform: scale(1.05);
            box-shadow: 0 4px 12px rgba(20, 184, 166, 0.3);
            border: none
        }
        .cal-day.normal { background: rgba(255, 255, 255, .04); border-color: rgba(255, 255, 255, .02); color: #e2e8f0 }
        .cal-day.special-sorrow { border: 1px solid rgba(239, 68, 68, 0.5); background: rgba(239, 68, 68, 0.12); color: #fca5a5; }
        .cal-day.special-joy { border: 1px solid rgba(16, 185, 129, 0.5); background: rgba(16, 185, 129, 0.12); color: #a7f3d0; }
        
        .small-text { font-size: .75rem; color: #94a3b8 }
        
        .compass-icon-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            background: rgba(20, 184, 166, .15);
            border: 1px solid rgba(20, 184, 166, .3);
            color: #2dd4bf;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            cursor: pointer;
            z-index: 5;
            transition: all .2s
        }
        .compass-icon-btn:hover { background: rgba(20, 184, 166, .25) }
        
        .compass-modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(15, 23, 42, .92); backdrop-filter: blur(12px);
            z-index: 100; display: flex; align-items: center; justify-content: center; flex-direction: column
        }
        .compass-modal {
            background: rgba(30, 41, 59, .75); border: 1px solid rgba(255, 255, 255, .1);
            border-radius: 32px; padding: 24px; text-align: center; max-width: 360px; width: 92%;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, .5);
            position: relative;
        }
        .compass-finder-container {
            width: 240px; height: 240px; margin: 20px auto; position: relative; border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,0.02) 0%, rgba(0,0,0,0.3) 100%);
            border: 3px dashed rgba(255, 255, 255, 0.15);
            display: flex; align-items: center; justify-content: center;
            cursor: grab; touch-action: none;
        }
        .compass-finder-container:active { cursor: grabbing; }
        .qibla-ring-indicator {
            position: absolute; width: 100%; height: 100%; border-radius: 50%;
            border: 2px solid rgba(20, 184, 166, 0.2); transition: all 0.15s ease-out;
        }
        .qibla-ring-indicator.aligned {
            border: 4px solid #10b981;
            box-shadow: 0 0 25px rgba(16, 185, 129, 0.5);
        }
        .kaaba-icon {
            position: absolute; width: 44px; height: 44px;
            background: #1e293b; border: 2px solid #ef4444; border-radius: 50%;
            display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
            bottom: calc(50% - 22px); left: calc(50% - 22px);
            transform-origin: center center; z-index: 10;
            box-shadow: 0 4px 10px rgba(0,0,0,0.5);
            transition: all 0.15s ease-out;
        }
        .qibla-ring-indicator.aligned .kaaba-icon {
            border-color: #10b981;
            background-color: #10b981;
        }
        .phone-pointer {
            position: absolute; top: 8px; width: 4px; height: 26px;
            background: #5eead4; border-radius: 2px; z-index: 15;
            box-shadow: 0 0 8px #2dd4bf;
        }
        .compass-close-btn { background: rgba(255, 255, 255, .1); border: 1px solid rgba(255, 255, 255, .15); color: white; padding: 10px 32px; border-radius: 24px; margin-top: 16px; font-size: .9rem; cursor: pointer; font-weight: 600; }
        .compass-close-btn:hover { background: rgba(255,255,255,0.2); }
        .qibla-info { color: #93c5fd; font-size: .85rem; margin: 8px 0; display: flex; justify-content: center; gap: 16px; font-family: monospace }
        .compass-hint { font-size: 0.75rem; color: #94a3b8; margin-top: 4px; }
        
        .sync-btn-container { display: flex; align-items: center; justify-content: space-between; margin-top: 6px; }
        .offset-btn {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.15);
            color: #e2e8f0;
            border-radius: 6px;
            width: 28px;
            height: 28px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
        }
        .offset-btn:hover { background: rgba(20, 184, 166, 0.2); border-color: #2dd4bf; }
        
        .event-banner {
            margin-top: 12px;
            font-size: 0.85rem;
            padding: 10px 14px;
            border-radius: 12px;
            background: rgba(255,255,255,0.03);
            border-right: 4px solid #94a3b8;
            color: #cbd5e1;
            display: none;
            font-weight: 500;
        }
        .event-banner.sorrow { border-right-color: #ef4444; background: rgba(239, 68, 68, 0.06); color: #fca5a5; display: block; }
        .event-banner.joy { border-right-color: #10b981; background: rgba(16, 185, 129, 0.06); color: #a7f3d0; display: block; }
    </style>
</head>
<body>
<div class="main-grid">
    <div style="grid-column:span 6" class="panel">
        <div class="compass-icon-btn" id="compassIcon" title="البوصلة">🧭</div>
        <div style="text-align:center;margin-bottom:16px">
            <h1 class="gradient-text" style="font-size:2rem;font-weight:800">نُور</h1>
            <div style="display:flex;justify-content:center;align-items:center;gap:8px;direction:ltr;margin-top:4px">
                <button id="rl" style="font-size:.65rem;background:rgba(20,184,166,.1);border:1px solid rgba(20,184,166,.2);color:#2dd4bf;border-radius:4px;padding:4px 10px;cursor:pointer;font-weight:bold;">تزامن الموقع 📍</button>
                <span id="ld" style="font-size:.75rem;color:#94a3b8;max-width:180px;overflow:hidden;white-space:nowrap">القطيف</span>
            </div>
            <div style="margin:8px 0"><div id="clk" class="digital-clock" style="font-size:2.5rem"></div></div>
            <div id="dt" class="small-text"></div>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px">
            <div id="pf" class="prayer-card"><span>🌙 الفجر</span><span class="prayer-time" id="tf">--:--</span></div>
            <div id="ps" class="prayer-card" style="opacity:.4"><span>☀️ الشروق</span><span class="prayer-time" id="ts">--:--</span></div>
            <div id="pd" class="prayer-card"><span>🌞 الظهر</span><span class="prayer-time" id="td">--:--</span></div>
            <div id="pa" class="prayer-card"><span>⛅ العصر</span><span class="prayer-time" id="ta">--:--</span></div>
            <div id="pm" class="prayer-card"><span>🌅 المغرب</span><span class="prayer-time" id="tm">--:--</span></div>
            <div id="pi" class="prayer-card"><span>🌙 العشاء</span><span class="prayer-time" id="ti">--:--</span></div>
        </div>
        <div style="margin-top:12px;border-top:1px solid rgba(255,255,255,.1);padding-top:12px">
            <button id="abtn" style="width:100%;padding:12px;border-radius:12px;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.3);color:#fcd34d;font-size:.8rem;letter-spacing:.05em"><span id="aic">🔔</span> <span id="atx">تفعيل التنبيهات الصوتية</span></button>
        </div>
    </div>
    
    <div style="grid-column:span 6;display:flex;flex-direction:column;gap:16px">
        <div class="panel" style="display:flex;align-items:center;justify-content:center;min-height:360px">
            <div class="circle-container">
                <svg width="100%" height="100%" viewBox="0 0 378 378">
                    <circle cx="189" cy="189" r="170" stroke="rgba(255,255,255,.03)" stroke-width="12" fill="transparent"/>
                    <circle id="arc" cx="189" cy="189" r="170" stroke="url(#g)" stroke-width="10" stroke-linecap="round" fill="transparent" stroke-dasharray="1068" stroke-dashoffset="0" transform="rotate(-90 189 189)"/>
                    <defs>
                        <linearGradient id="g" x1="0%" y1="0%" x2="100%" y2="100%"><stop offset="0%" stop-color="#2dd4bf"/><stop offset="100%" stop-color="#10b981"/></linearGradient>
                    </defs>
                </svg>
                <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center">
                    <span style="font-size:.7rem;color:#2dd4bf;font-weight:600;letter-spacing:.1em">الصلاة القادمة</span>
                    <h2 id="cn" style="font-size:1.8rem;color:#fff;margin:6px 0">--</h2>
                    <div id="ct" class="countdown-timer" style="font-size:2.2rem">00:00:00</div>
                    <span style="font-size:.65rem;color:#94a3b8;margin-top:4px">الوقت المتبقي</span>
                </div>
            </div>
        </div>
        
        <div class="panel">
            <div style="display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid rgba(255,255,255,.1);padding-bottom:12px;margin-bottom:12px">
                <button id="pmb" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:#cbd5e1;padding:4px 12px;border-radius:8px">&gt;</button>
                <div style="text-align:center">
                    <h3 id="cmn" style="font-size:1.2rem;color:#2dd4bf;font-weight:700">--</h3>
                    <p id="cgr" style="font-size:.7rem;color:#94a3b8;margin-top:2px"></p>
                </div>
                <button id="nmb" style="background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:#cbd5e1;padding:4px 12px;border-radius:8px">&lt;</button>
            </div>
            <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center;font-size:.8rem;color:#94a3b8;margin-bottom:8px">
                <div>ح</div><div>ن</div><div>ث</div><div>ر</div><div>خ</div><div>ج</div><div>س</div>
            </div>
            <div id="cdg" style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;text-align:center"></div>
            
            <div id="todayEventBanner" class="event-banner"></div>

            <div style="margin-top:12px;background:rgba(20,184,166,.05);border:1px solid rgba(20,184,166,.1);border-radius:12px;padding:12px">
                <div class="sync-btn-container">
                    <div style="font-size:.8rem;color:#2dd4bf;display:flex;align-items:center;gap:6px"><span>📅</span> التاريخ الهجري الشرعي اليوم:</div>
                    <div style="display:flex;gap:4px">
                        <button class="offset-btn" id="decOffset" title="تأخير يوم">-</button>
                        <button class="offset-btn" id="incOffset" title="تقديم يوم">+</button>
                    </div>
                </div>
                <p id="thj" style="font-size:.95rem;color:#fff;margin-top:6px;margin-bottom:0;font-weight:600">--</p>
            </div>
        </div>
    </div>
</div>

<div id="compassModal" style="display:none" class="compass-modal-overlay">
    <div class="compass-modal">
        <h3 style="margin:0;color:#fff;font-size:1.1rem;">محدد اتجاه القبلة التفاعلي</h3>
        <p class="compass-hint" id="statusHint">قم بتدوير الدائرة بيدك لتوجيه الهاتف نحو القبلة</p>
        
        <div class="compass-finder-container" id="compassContainer">
            <div class="phone-pointer"></div>
            <div class="qibla-ring-indicator" id="qiblaRing">
                <div class="kaaba-icon" id="kaabaIcon">🕋</div>
            </div>
        </div>
        
        <div class="qibla-info">
            <span>زاوية القبلة: <strong id="targetAngleText" style="color:#2dd4bf">--°</strong></span>
            <span>اتجاهك الحالي: <strong id="currentAngleText" style="color:#ef4444">--°</strong></span>
        </div>
        <button class="compass-close-btn" id="closeCompass">تم</button>
    </div>
</div>

