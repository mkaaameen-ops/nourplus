function qiblaDirection(lat1,lon1,lat2,lon2){
 var dLon = toRad(lon2 - lon1);
 var y = Math.sin(dLon);
 var x = Math.cos(toRad(lat1))*Math.tan(toRad(lat2)) - Math.sin(toRad(lat1))*Math.cos(dLon);
 return toDeg(Math.atan2(y,x));
}
var KAABA_LAT = 21.4225, KAABA_LON = 39.8262;
var qiblaDeg = qiblaDirection(lat,lng,KAABA_LAT,KAABA_LON);
if(qiblaDeg<0) qiblaDeg+=360;

var currentHeading = 0; 
var isDragging = false;
var startAngle = 0;

function updateCompassView(heading) {
    currentHeading = (heading + 360) % 360;
    if(qiblaRing) qiblaRing.style.transform = 'rotate(' + (-currentHeading) + 'deg)';
    if(kaabaIcon) kaabaIcon.style.transform = 'rotate(' + (qiblaDeg) + 'deg)';
    if(targetAngleText) targetAngleText.textContent = Math.round(qiblaDeg) + "°";
    if(currentAngleText) currentAngleText.textContent = Math.round(currentHeading) + "°";
    
    var diff = Math.abs(currentHeading - qiblaDeg);
    if (diff > 180) diff = 360 - diff;
    
    if (diff <= 5) {
        if(qiblaRing) qiblaRing.classList.add("aligned");
        if(statusHint) {
            statusHint.textContent = "أنت تواجه الكعبة المشرفة تماماً! 🕋";
            statusHint.style.color = "#10b981";
        }
        if (window.navigator.vibrate) window.navigator.vibrate(40);
    } else {
        if(qiblaRing) qiblaRing.classList.remove("aligned");
        if(statusHint) {
            statusHint.textContent = "قم بتدوير الدائرة بيدك لتوجيه الهاتف نحو القبلة";
            statusHint.style.color = "#94a3b8";
        }
    }
}

function getAngle(clientX, clientY) {
    if(!compassContainer) return 0;
    var rect = compassContainer.getBoundingClientRect();
    var centerX = rect.left + rect.width / 2;
    var centerY = rect.top + rect.height / 2;
    return toDeg(Math.atan2(clientY - centerY, clientX - centerX));
}

function startDrag(e) {
    isDragging = true;
    var pageX = e.touches ? e.touches[0].clientX : e.clientX;
    var pageY = e.touches ? e.touches[0].clientY : e.clientY;
    startAngle = getAngle(pageX, pageY) - currentHeading;
    e.preventDefault();
}
function doDrag(e) {
    if (!isDragging) return;
    var pageX = e.touches ? e.touches[0].clientX : e.clientX;
    var pageY = e.touches ? e.touches[0].clientY : e.clientY;
    var angle = getAngle(pageX, pageY);
    updateCompassView(angle - startAngle);
}
function stopDrag() { isDragging = false; }

if(compassContainer) {
    compassContainer.addEventListener('mousedown', startDrag);
    compassContainer.addEventListener('mousemove', doDrag);
    window.addEventListener('mouseup', stopDrag);
    compassContainer.addEventListener('touchstart', startDrag, {passive: false});
    compassContainer.addEventListener('touchmove', doDrag, {passive: false});
    window.addEventListener('touchend', stopDrag);
}

function handleOrientation(e) {
    var heading = e.webkitCompassHeading || (e.alpha !== null ? 360 - e.alpha : null);
    if (heading !== null && !isDragging) {
        updateCompassView(heading);
    }
}

if(compassIcon) {
    compassIcon.onclick = function() {
        if(compassModal) compassModal.style.display = 'flex';
        qiblaDeg = qiblaDirection(lat, lng, KAABA_LAT, KAABA_LON);
        if(qiblaDeg < 0) qiblaDeg += 360;
        updateCompassView(0);
        
        if (typeof DeviceOrientationEvent !== 'undefined' && typeof DeviceOrientationEvent.requestPermission === 'function') {
            DeviceOrientationEvent.requestPermission().then(function(s){ if(s==='granted') window.addEventListener('deviceorientation', handleOrientation); });
        } else {
            window.addEventListener('deviceorientation', handleOrientation);
        }
    };
}

if(closeCompassBtn) {
    closeCompassBtn.onclick = function() {
        if(compassModal) compassModal.style.display = 'none';
        window.removeEventListener('deviceorientation', handleOrientation);
    };
}

