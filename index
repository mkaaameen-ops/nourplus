function rp(){var n=new Date();var tz=-n.getTimezoneOffset()/60;var p=SPE.calc(lat,lng,tz,n);Object.keys(te).forEach(function(k){if(te[k]) te[k].textContent=ft(p[k]);});var now=n.getTime();var cur="isha",prev=p.isha,nx="fajr",nxL="الفجر";if(now>=p.fajr.getTime()&&now<p.sunrise.getTime()){cur="fajr";prev=p.fajr;nx="sunrise";nxL="الشروق";}else if(now>=p.sunrise.getTime()&&now<p.dhuhr.getTime()){cur="sunrise";prev=p.sunrise;nx="dhuhr";nxL="الظهر";}else if(now>=p.dhuhr.getTime()&&now<p.asr.getTime()){cur="dhuhr";prev=p.dhuhr;nx="asr";nxL="العصر";}else if(now>=p.asr.getTime()&&now<p.maghrib.getTime()){cur="asr";prev=p.asr;nx="maghrib";nxL="المغرب";}else if(now>=p.maghrib.getTime()&&now<p.isha.getTime()){cur="maghrib";prev=p.maghrib;nx="isha";nxL="العشاء";}
Object.values(pc).forEach(function(c){if(c) c.classList.remove("active");});if(pc[cur])pc[cur].classList.add("active");if(cur!=="sunrise"&&(!initTrig||cur!==lastTrig)){if(initTrig) chime(); initTrig=true;}lastTrig=cur;if(cn) cn.textContent=nxL;var tN=p[nx];if(nx==="fajr"&&now>=p.isha.getTime()){var tom=new Date();tom.setDate(tom.getDate()+1);tN=SPE.calc(lat,lng,tz,tom).fajr;}var diff=tN.getTime()-now;if(diff>0){var sec=Math.floor(diff/1000);if(ct) ct.textContent=String(Math.floor(sec/3600)).padStart(2,"0")+":"+String(Math.floor((sec%3600)/60)).padStart(2,"0")+":"+String(sec%60).padStart(2,"0");var tw=tN.getTime()-prev.getTime();if(tw>0){var pct=diff/tw;if(arc){arc.style.transition="none";arc.setAttribute("stroke-dashoffset",1068*(1-pct));void arc.offsetWidth;arc.style.transition="stroke-dashoffset 1s linear";}}}else{if(ct) ct.textContent="00:00:00";if(arc) arc.setAttribute("stroke-dashoffset","1068");}}

function getAdjustedHijri(dateObj) {
  var targetDate = new Date(dateObj.getTime());
  targetDate.setDate(targetDate.getDate() + hOffset);
  return SCE.hijri(targetDate);
}

function findShiaEvent(hMonth, hDay) {
  return shiaEvents.find(function(e) { return e.m === hMonth && e.d === hDay; }) || null;
}

function rc(){
  if(!cmn || !cdg) return;
  cmn.textContent = MIL_MONTH_NAMES[calM] + " " + calY;
  var firstMilDate = new Date(calY, calM, 1);
  var dim = new Date(calY, calM + 1, 0).getDate();
  var hFirst = getAdjustedHijri(firstMilDate);
  var hLast = getAdjustedHijri(new Date(calY, calM, dim));
  if(cgr) cgr.textContent = SCE.monthName(hFirst.hMonth) + " " + hFirst.hYear + " - " + SCE.monthName(hLast.hMonth) + " " + hLast.hYear + " هـ";
  cdg.innerHTML = "";
  var sd = firstMilDate.getDay();
  for(var i=0; i<sd; i++){ cdg.appendChild(document.createElement("div")); }
  var now = new Date();
  var todayEventText = "";
  var todayEventType = "";
  for(var d=1; d<=dim; d++){
    var cell = document.createElement("div");
    var currentMilDate = new Date(calY, calM, d);
    var hObj = getAdjustedHijri(currentMilDate);
    cell.innerHTML = "<span>" + d + "</span><span style='font-size:0.7rem;color:#94a3b8;margin-top:1px;font-weight:normal;'>" + hObj.hDay + "</span>";
    var cls = "cal-day ";
    if(d === now.getDate() && calM === now.getMonth() && calY === now.getFullYear()) { cls += "today"; } else { cls += "normal"; }
    var ev = findShiaEvent(hObj.hMonth, hObj.hDay);
    if(ev) {
      if(ev.t === "sorrow") cls += " special-sorrow";
      else if(ev.t === "joy") cls += " special-joy";
      if(d === now.getDate() && calM === now.getMonth() && calY === now.getFullYear()) {
        todayEventText = "مناسبة اليوم: " + ev.n + " (" + hObj.hDay + " " + SCE.monthName(hObj.hMonth) + ")";
        todayEventType = ev.t;
      }
    }
    cell.className = cls;
    cdg.appendChild(cell);
  }
  if(todayEventBanner) {
    if(todayEventText) { todayEventBanner.textContent = todayEventText; todayEventBanner.className = "event-banner " + todayEventType; } 
    else { todayEventBanner.style.display = "none"; }
  }
}

function ua(){
  uc();
  rp();
  var now = new Date();
  var tH = getAdjustedHijri(now);
  var offsetText = hOffset !== 0 ? " (" + (hOffset > 0 ? "+" : "") + hOffset + " يوم)" : "";
  if(thj) thj.textContent = tH.hDay + " " + SCE.monthName(tH.hMonth) + " " + tH.hYear + " هـ" + offsetText;
  if(calY === 0){ calY = now.getFullYear(); calM = now.getMonth(); }
  rc();
}

function sv(la,lo,lb){
  lat=la; lng=lo; locName=lb; if(ld) ld.textContent=lb;
  qiblaDeg = qiblaDirection(lat,lng,KAABA_LAT,KAABA_LON); if(qiblaDeg<0) qiblaDeg+=360;
  saveAllData();
}

function triggerGPS() {
  if (navigator.geolocation) {
    if (window.location.protocol === 'file:') {
      alert("💡 تنبيه النظام:\nعند تشغيل الملف محلياً بدون سيرفر، يتم حظر الـ GPS تلقائياً لحمايتك. تم تشغيل مواقيت (القطيف الافتراضية) فوراً.");
      sv(26.5258, 49.9981, "القطيف (افتراضي)");
      ua();
      return;
    }
    if(ld) ld.textContent = "📡 جاري التزامن...";
    navigator.geolocation.getCurrentPosition(function(pos) {
        sv(pos.coords.latitude, pos.coords.longitude, "📍 موقع (GPS)");
        ua();
    }, function(err) {
        sv(26.5258, 49.9981, "القطيف (افتراضي)");
        ua();
    }, { enableHighAccuracy: false, timeout: 4000 });
  } else {
    sv(26.5258, 49.9981, "القطيف (افتراضي)");
    ua();
  }
}

if(incOffset) incOffset.onclick=function(){ hOffset++; saveAllData(); ua(); };
